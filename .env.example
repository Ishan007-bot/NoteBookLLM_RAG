# Groq API key — used for the LLM (chat completion).
# Get one free at: https://console.groq.com/keys
GROQ_API_KEY=
# Optional backup keys. The app rotates to the next one if the primary key
# returns 429 / quota errors. Up to 5 total (GROQ_API_KEY through _5).
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Google AI Studio API key — used for embeddings (gemini-embedding-001).
# Get one free at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional backup keys (same rotation behaviour as Groq).
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=

# Qdrant vector database connection.
# Local development: run `docker run -p 6333:6333 qdrant/qdrant` and use http://127.0.0.1:6333 (no API key needed)
# Production: sign up at https://cloud.qdrant.io and use the cluster URL + API key
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
