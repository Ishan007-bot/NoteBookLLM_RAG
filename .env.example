# Groq API key — used for the LLM (chat completion).
# Get one free at: https://console.groq.com/keys
GROQ_API_KEY=

# Google AI Studio API key — used for embeddings (text-embedding-004).
# Get one free at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Qdrant vector database connection.
# Local development: run `docker run -p 6333:6333 qdrant/qdrant` and use http://localhost:6333 (no API key needed)
# Production: sign up at https://cloud.qdrant.io and use the cluster URL + API key
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
